<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="MultiBrowserTesting" parallel="tests">
	<test name="ChromeTest">
		<parameter name="Browser" value="chrome"></parameter>
		<classes>

			<class name="testscript.ManageCategoryTest">

				<methods>
					<include name="verifyUserCanAddCategories"></include>
				</methods>
			</class>
			<class name="testscript.ManageNewsTest"></class>
			<class name="testscript.ManageDeliveryBoyTest"></class>
			<class name="testscript.AdminUserTest"></class>
			<class name="testscript.ManageCODTest"></class>



		</classes>
	</test> <!--
	Test -->
	<test name="FireFoxTest">
		<parameter name="Browser" value="firefox"></parameter>
		<classes>
			<class name="testscript.ManageCategoryTest">

				<methods>
					<include name="verifyUserCanAddCategories"></include>
				</methods>
			</class>
			<class name="testscript.ManageNewsTest"></class>
			<class name="testscript.ManageDeliveryBoyTest"></class>
			<class name="testscript.AdminUserTest"></class>
			<class name="testscript.ManageCODTest"></class>

		</classes>
	</test>
</suite> <!--
Suite -->
